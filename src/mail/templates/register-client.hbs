<html lang='es'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Nuevo cliente registrado</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        color: #333;
        background-color: #f4f4f4;
        margin: 0;
        padding: 0;
      }
      .container {
        max-width: 600px;
        margin: 20px auto;
        background-color: #ffffff;
        padding: 20px;
        border-radius: 8px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
      }
      h1 {
        color: #2c3e50;
        font-size: 24px;
        text-align: center;
        margin: 0 0 20px 0;
      }
      .highlight {
        background-color: #eaf2f8;
        border-left: 4px solid #27ae60;
        padding: 10px;
        border-radius: 4px;
        margin-bottom: 20px;
      }
      p {
        font-size: 16px;
        line-height: 1.5;
        margin: 10px 0;
      }
      .info-box {
        background-color: #f8f9f9;
        border-radius: 6px;
        padding: 15px;
        margin-top: 15px;
      }
      .info-box p {
        margin: 5px 0;
        font-size: 15px;
      }
      .footer {
        font-size: 14px;
        color: #7f8c8d;
        text-align: center;
        margin-top: 20px;
      }
    </style>
  </head>
  <body>
    <table width='100%' cellspacing='0' cellpadding='0' border='0'>
      <tr>
        <td align='center'>
          <div class='container'>
            <h1>Nuevo Cliente Registrado</h1>

            <div class='highlight'>
              <p>Se ha registrado un nuevo cliente en el sistema.</p>
            </div>

            <div class='info-box'>
              <p><strong>Nombre:</strong> {{name}}</p>
              <p><strong>Correo:</strong> {{email_user}}</p>
              <p><strong>Teléfono:</strong> {{phone}}</p>
            </div>

            <div class='footer'>
              <p>Este es un mensaje automático del sistema.</p>
              <p>El Sembrador © {{year}}</p>
            </div>
          </div>
        </td>
      </tr>
    </table>
  </body>
</html>